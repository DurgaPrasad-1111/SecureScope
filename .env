# Backend env
APP_NAME=SecureScope
ENVIRONMENT=production
DEBUG=false
DATABASE_URL=postgresql+psycopg2://securescope:securescope@db:5432/securescope
JWT_SECRET_KEY=SecureScope@JWT@Key!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_MINUTES=20
REFRESH_TOKEN_EXP_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://localhost
ENCRYPTION_KEY=SecureScope@Encryption@Key!
RATE_LIMIT_DEFAULT=100/minute
REPORT_STORAGE_PATH=/app/reports

# Frontend env
VITE_API_BASE_URL=/api/v1
INITIAL_ADMIN_EMAIL=admin@securescope.app
INITIAL_ADMIN_PASSWORD=SecureScope@Admin@Password!
INITIAL_ADMIN_NAME=Platform Admin
