# Copy to .env (next to docker-compose.yml) and customize.
#
# MySQL
MYSQL_ROOT_PASSWORD=recon_root_password
MYSQL_DATABASE=recon_db
MYSQL_USER=recon_user
MYSQL_PASSWORD=recon_password
MYSQL_HOST_PORT=3320
#
# Backend
APP_ENV=production
FLASK_DEBUG=0

# Change these in production.
SECRET_KEY=4v8pNf3r9Qz1uX7kM2aB6cD0yT9wS5eL8jH1nP3rF6uZ2sX7
JWT_SECRET=f2K9wQ7sX1bR6nP4tY8uE5mA3dC9hV2jL7qW1sZ6vN8pK0rT4
# Required in production for /setup (one-time admin creation).
SETUP_TOKEN=7sX1bR6nP4tY8uE5mA3dC9hV2jL7qW1sZ6

ENABLE_TOTP=1
TOTP_ISSUER=ReconEngine

# SECRET_KEY=SECRET_KEY
# JWT_SECRET=JWT_SECRET
ENABLE_DB_CREATE_ALL=0
DB_AUTO_INIT=1
WAIT_FOR_DB=1
WAIT_FOR_DB_TIMEOUT_SECONDS=60
WAIT_FOR_DB_INTERVAL_SECONDS=2
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
SIGNUP_RATE_LIMIT=5
SIGNUP_RATE_WINDOW_SEC=300
ALLOW_SIGNUP=1
SCAN_TIME_BUDGET_SECONDS=90
SCAN_TOOL_TIMEOUT_SECONDS=25
SCAN_SUBDOMAIN_TOOL_TIMEOUT_SECONDS=15
SCAN_URL_DISCOVERY_TIMEOUT_SECONDS=20
SCAN_PORT_SCAN_TIMEOUT_SECONDS=25
SCAN_WHOIS_TIMEOUT_SECONDS=6
#
# Cookies/CORS
SESSION_COOKIE_SECURE=1
CORS_ORIGINS=https://your-domain.com
#
# Nginx
NGINX_PORT=80
